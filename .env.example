# Cloud sync (Supabase) — see epic #71. Copy to .env.local and fill in.
# All three are exposed to the browser bundle (VITE_ prefix). The anon key is
# PUBLIC by design; security is enforced by RLS + capability tokens, not secrecy.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Your Supabase "anon" public API key
VITE_SUPABASE_ANON_KEY=

# Feature flag. Cloud sync stays OFF unless this is exactly "on".
VITE_CLOUD_SYNC=
