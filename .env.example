# Cloud sync (Supabase) — see epic #71. Copy to .env.local and fill in.
# All three are exposed to the browser bundle (VITE_ prefix). The anon key is
# PUBLIC by design; security is enforced by RLS + capability tokens, not secrecy.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Your Supabase "anon" public API key
VITE_SUPABASE_ANON_KEY=

# Feature flag. Guest cloud sync (capability-token plane, epic #71) stays OFF
# unless this is exactly "on". Not required when VITE_AUTH=on (auth implies cloud).
VITE_CLOUD_SYNC=

# Feature flag (epic #109). Set to exactly "on" to enable multi-user accounts:
# magic-link sign-in, per-user roles (player / gm / admin), and cloud-as-source-
# of-truth character storage. Implies cloud. Guest #c=/#play=/#share= links keep
# working without login regardless of this flag. Leave blank for the legacy
# single-user / guest-only build.
VITE_AUTH=
